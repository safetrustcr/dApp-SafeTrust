NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_HASURA_GRAPHQL_URL=http://localhost:8080/v1/graphql
NEXT_PUBLIC_HASURA_WS_URL=ws://localhost:8080/v1/graphql

# Hasura (server-side only — do NOT prefix with NEXT_PUBLIC)
HASURA_ADMIN_SECRET=your_hasura_admin_secret_here
HASURA_GRAPHQL_URL=http://localhost:8080/v1/graphql

# TrustlessWork (server-side only — do NOT prefix with NEXT_PUBLIC)
TRUSTLESS_WORK_API_KEY=your_trustlesswork_api_key_here
TRUSTLESS_WORK_API_URL=https://dev.api.trustlesswork.com

# TrustlessWork (client-side)
NEXT_PUBLIC_TRUSTLESS_WORK_API_KEY=your_trustlesswork_api_key_here
NEXT_PUBLIC_TRUSTLESS_WORK_ENV=development

# Stellar escrow config
NEXT_PUBLIC_PLATFORM_ADDRESS=your_stellar_platform_address_here
NEXT_PUBLIC_USDC_ADDRESS=your_usdc_trustline_address_here
