# Copy to .env.local for local Next.js development (see repo root .env.example for full stack).

# Hasura GraphQL (Apollo Client at runtime)
NEXT_PUBLIC_HASURA_GRAPHQL_URL=http://localhost:8080/v1/graphql

# Optional: introspect a running Hasura for graphql-codegen (defaults to committed stub if unset)
# CODEGEN_SCHEMA_URL=http://localhost:8080/v1/graphql
NEXT_PUBLIC_HASURA_WS_URL=ws://localhost:8080/v1/graphql

# Firebase client (see README)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
