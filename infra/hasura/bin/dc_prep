#!/bin/bash
set -e

echo "🚀 Starting SafeTrust backend..."

echo "📦 Starting containers..."
docker compose up -d

echo "⏳ Waiting for Hasura to be healthy..."
until curl -sf http://localhost:8080/healthz > /dev/null; do
  sleep 2
done

echo "🏗️ Deploying safetrust tenant metadata..."
cd metadata
./setup-tenant.sh safetrust \
  --endpoint http://localhost:8080 \
  --admin-secret myadminsecretkey
cd ..

echo "📂 Applying migrations..."
hasura migrate apply \
  --endpoint http://localhost:8080 \
  --admin-secret myadminsecretkey \
  --database-name safetrust

echo "🌱 Applying seeds..."
hasura seed apply \
  --endpoint http://localhost:8080 \
  --admin-secret myadminsecretkey \
  --database-name safetrust

echo ""
echo "✅ SafeTrust backend ready"
echo "   GraphQL:    http://localhost:8080/v1/graphql"
echo "   PostgreSQL: localhost:5433"
echo "   Webhook:    http://localhost:3000"
echo ""
echo "👉 To open Hasura console:"
echo "   hasura console --endpoint http://localhost:8080 --admin-secret myadminsecretkey"