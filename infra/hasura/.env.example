# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=#postgresuser
POSTGRES_PASSWORD=#postgrespassword
POSTGRES_DB=#postgresdb
POSTGRES_HOST=#localhost
POSTGRES_PORT=#5432
PG_DATABASE_URL=#postgres://postgres:postgrespassword@localhost:5433/postgres

# ── Hasura ───────────────────────────────────────────────
HASURA_GRAPHQL_ADMIN_SECRET=#myadminsecretkey
HASURA_GRAPHQL_JWT_SECRET=#{"type":"HS256","key":"myadminsecretkey-32charminimumrequired"}
HASURA_EVENT_SECRET=#dev-event-secret-local
WEBHOOK_URL=#http://safetrust-webhook:3000

# ── Firebase Admin SDK ──────────────────────────────────
FIREBASE_PROJECT_ID=#safetrustcr-596e3
FIREBASE_CLIENT_EMAIL=##firebase_client_email##
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<from_downloaded_json>\n-----END PRIVATE KEY-----\n"