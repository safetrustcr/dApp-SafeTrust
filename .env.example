# TrustlessWork SDK
NEXT_PUBLIC_TRUSTLESS_WORK_API_KEY=your_api_key_here
NEXT_PUBLIC_TRUSTLESS_WORK_ENV=development

# TrustlessWork escrow roles
NEXT_PUBLIC_PLATFORM_ADDRESS=your_platform_stellar_address
NEXT_PUBLIC_USDC_ADDRESS=your_usdc_trustline_address

# Hasura server-side access
HASURA_GRAPHQL_URL=http://localhost:8080/v1/graphql
HASURA_GRAPHQL_ADMIN_SECRET=myadminsecretkey

# TrustlessWork webhook validation
TRUSTLESS_WORK_WEBHOOK_SECRET=your_webhook_secret
