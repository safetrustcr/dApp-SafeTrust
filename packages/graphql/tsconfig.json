{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "generated",
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["generated/**/*.ts"]
}
